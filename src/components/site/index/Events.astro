---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import HorizontalLine from '../../animation/HorizontalLine.astro';
import VerticalLine from '../../animation/VerticalLine.astro';
const events = await getCollection('events');
---

<section class="p-0 min-h-[75vh]">
    <HorizontalLine direction="left" color="black" width="100%" />
    <div class="flex justify-center items-center w-full py-10">
        <h2>Unsere Veranstaltungen</h2>
    </div>
    <HorizontalLine direction="right" color="black" width="100%" />
    
    <div class="overflow-hidden p-0 h-full">
        <div class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth">

            {events.map((event) => (
                <a 
                    href={`/events/${event.id}`} 
                    class="relative w-1/3 h-[75vh] snap-center overflow-hidden group"
                >
                    <Image 
                        src={event.data.cover} 
                        alt={event.data.title}
                        class="absolute inset-0 w-full h-full object-cover"
                    />
                    <div class="absolute inset-0 bg-black/40 group-hover:bg-black/50 transition-colors" />
                    <div class="relative z-10 flex flex-col justify-end h-full p-6 text-white">
                        <h3 class="text-xl mb-2">{event.data.title}</h3>
                        <p>
                            {event.data.date.toLocaleDateString('de-AT', { 
                                day: 'numeric', 
                                month: 'long', 
                                year: 'numeric' 
                            })}
                        </p>
                    </div>
                </a>
            <VerticalLine direction="top" color="black" />
            ))}
        </div>
    </div>
</section>