---
import { Image } from "astro:assets";
import HorizontalLine from "../../animation/HorizontalLine.astro";
import ContactForm from "./ContactForm.astro";
---

<section>
  <HorizontalLine direction="left" color="black" width="100%" />
  <div class="flex flex-col w-full justify-center items-center py-10">
    <h2>Können wir helfen?</h2>
  </div>
  <HorizontalLine direction="right" color="black" width="100%" />
  <div class="flex flex-row">
    <div class="w-1/3 p-5">
        <ContactForm />
    </div>
    <div class="w-2/3 p-5">
        <Image
            src="/klosterneuburg_karte_hd.jpg"
            class="w-full h-full object-cover"
            alt="Contact"
            width={100}
            height={100}
        />
    </div>
  </div>
</section>
