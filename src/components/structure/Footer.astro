---
import HorizontalLine from '../animation/HorizontalLine.astro';
import { Image } from 'astro:assets';

const FooterLinks = [
    {
        label: "Home",
        href: "/"
    },
    {
        label: "News",
        href: "#news"
    },
    {
        label: "Shop",
        href: "https://www.shop-weinbau-schmuckenschlager.com/"
    },
    {
        label: "Familie",
        href: "#familie"
    },
    {
        label: "Kontakt",
        href: "#kontakt"
    },
    {
        label: "Impressum",
        href: "/impressum"
    },
    {
        label: "Datenschutz",
        href: "/datenschutz"
    }
]
---
<footer class="flex flex-col h-25vh w-full py-10">
    <HorizontalLine direction="left" color="black" width="100%" />
    <div class="flex justify-start items-center p-5">
        <Image src="/logo_dark_transparent.png" alt="Logo" width={100} height={100} />
        <h4>Weinbau Schmuckenschlager</h4>
    </div>
    <div class="flex justify-start px-8 w-full">
        <ul class="flex flex-col gap-1 w-full">
            {FooterLinks.map((link) => (
                <a class="hover:text-gray-500" href={link.href}><li class="w-full"></li>{link.label}</li></a>
                <HorizontalLine direction="left" color="black" width="100%" />
            ))}
        </ul>
    </div>
</footer>
